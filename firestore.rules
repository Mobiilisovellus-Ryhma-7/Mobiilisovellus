rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for facility sections so app search can work without auth.
    match /facility_sections/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Keep all other collections locked down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
