rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for app test collections.
    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /users/{userId}/favorite_facilities/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /facilities/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /facility_sections/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Keep all other collections locked down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
